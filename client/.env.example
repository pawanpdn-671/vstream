# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ===== FRONTEND ENV VARIABLES =====
# Theme storage key
VITE_THEME_KEY=vstream-ui-theme-mode
VITE_API_BASE_URL=/api


# ===== BACKEND ENV VARIABLES (Set in Vercel Dashboard) =====
# These are NOT used in the client, but listed here for reference.
# Add these in Vercel Project Settings -> Environment Variables

# MongoDB
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
# DATABASE_NAME=vstream

# JWT Secrets
# JWT_SECRET_KEY=your-access-token-secret-min-32-chars
# JWT_REFRESH_SECRET_KEY=your-refresh-token-secret-min-32-chars

# CORS
# ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app

# AI Features (Groq)
# GROQ_API_KEY=gsk_xxxxx
# GET_MOVIE_PROMPT_TEMPLATE=Your AI prompt template for generating movies

# YouTube API (for trailers)
# YOUTUBE_API_KEY=AIzaSy-xxxxx

# OMDb API (for movie data - poster, IMDB ID)
# OMDB_API_KEY=xxxxxxxx

# Collect API (Optional - alternative movie data source)
# COLLECT_API_KEY=your-collect-api-key
# COLLECT_BASE_URL=https://api.example.com/movie?title={title}
